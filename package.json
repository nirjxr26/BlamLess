{
  "name": "pr-build-replay",
  "version": "1.0.0",
  "description": "Auto-retries failed workflows during GitHub infrastructure incidents",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build src/index.ts -o dist --minify",
    "prepare": "npm run build",
    "test": "npm run build && node .dev-tests/run-tests.js"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
